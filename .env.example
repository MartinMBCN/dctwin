FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
DCTWIN_MODEL_DEPLOYMENT=dctwin-gpt-5-mini
# Strongly recommended for browser/device-code auth. Find it in Azure Portal:
# Microsoft Entra ID → Overview → Tenant ID.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
# Default: device_code keeps Azure login in the terminal instead of redirecting the app browser.
# Set to "browser" only if you explicitly want interactive browser login.
DCTWIN_AUTH_MODE=device_code
DCTWIN_AUTH_TIMEOUT_SECONDS=180
# Default: staged_extraction. Set to "full" to compare the older one-shot DCT path.
DCTWIN_MODEL_PATH=staged_extraction

# AzureDeveloperCliCredential uses the signed-in azd executable.
AZD_CONFIG_DIR=/path/to/work/tools/azd-config
