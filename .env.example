FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
DCTWIN_MODEL_DEPLOYMENT=dctwin-gpt-5-mini
# Default: staged_extraction. Set to "full" to compare the older one-shot DCT path.
DCTWIN_MODEL_PATH=staged_extraction

# AzureDeveloperCliCredential uses the signed-in azd executable.
AZD_CONFIG_DIR=/path/to/work/tools/azd-config
