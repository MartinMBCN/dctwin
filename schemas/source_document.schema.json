{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dctwin.dev/schemas/source-document/0.1.0",
  "title": "Normalized Source Document",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_id", "source_type", "media_type", "content_hash", "ingested_at", "adapter", "privacy", "blocks"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "source_id": { "type": "string", "pattern": "^src_[a-zA-Z0-9_-]+$" },
    "source_type": {
      "type": "string",
      "enum": ["cv", "linkedin_profile", "portfolio", "interview_transcript", "story", "user_correction", "other"]
    },
    "media_type": { "type": "string", "minLength": 1 },
    "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "ingested_at": { "type": "string", "format": "date-time" },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "direct_identifiers_minimized", "enrollment_candidates_separated"],
      "properties": {
        "classification": { "const": "personal_data" },
        "direct_identifiers_minimized": { "type": "boolean" },
        "enrollment_candidates_separated": { "type": "boolean" }
      }
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "locator", "text", "redactions"],
        "properties": {
          "id": { "type": "string", "pattern": "^block_[a-zA-Z0-9_-]+$" },
          "locator": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "value"],
            "properties": {
                "kind": { "type": "string", "enum": ["page", "paragraph", "section", "url", "timestamp", "record"] },
              "value": { "type": "string", "minLength": 1 }
            }
          },
          "text": { "type": "string" },
          "redactions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["category", "placeholder"],
              "properties": {
                "category": { "type": "string", "enum": ["email", "phone", "street_address"] },
                "placeholder": { "type": "string", "pattern": "^\\[[A-Z_]+_[0-9]+\\]$" }
              }
            }
          }
        }
      }
    }
  }
}
